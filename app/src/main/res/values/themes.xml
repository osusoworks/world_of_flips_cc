<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Orimekun" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
        <item name="fontFamily">@font/yusei_magic</item>
        <item name="android:fontFamily">@font/yusei_magic</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

    <style name="Theme.Orimekun.Yomogi" parent="Theme.Orimekun">
        <item name="fontFamily">@font/yomogi</item>
        <item name="android:fontFamily">@font/yomogi</item>
    </style>

    <style name="Theme.Orimekun.Mplus" parent="Theme.Orimekun">
        <item name="fontFamily">@font/mplusrounded1c</item>
        <item name="android:fontFamily">@font/mplusrounded1c</item>
    </style>
</resources>
